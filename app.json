{
  "expo": {
    "name": "OJYQ",
    "slug": "OJYQ",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/IMG_Logo-Principale.png",
    "scheme": "OJYQ",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "org.ojyq.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "org.ojyq.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#14389c",
        "foregroundImage": "./assets/images/IMG_Logo-Principale.png",
        "backgroundImage": "./assets/images/IMG_Logo-Principale.png",
        "monochromeImage": "./assets/images/IMG_Logo-Principale.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/IMG_Logo-Principale.png"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      [
        "expo-notifications",
        {
          "color": "#14389c",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/IMG_Logo-Principale.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#081129",
          "dark": {
            "backgroundColor": "#081129"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "311453cc-2bde-43a1-923d-47dbfc299172"
      }
    },
    "owner": "ojyq"
  }
}
